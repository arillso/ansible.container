---
exclude_paths:
    - .ansible/
    - .github/
    - .venv/
    - venv/
    - roles/fleet/meta/argument_specs.yml # Duplicate merge keys not supported by ruamel.yaml

skip_list:
    - galaxy[version-incorrect]
    - var-naming[no-role-prefix]
    - command-instead-of-module
    - no-handler
    - package-latest

warn_list:
    - name[casing]
    - yaml[line-length]

use_default_rules: true
